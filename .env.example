# Optional: only if you prefer env file over Keychain.
# Prefer macOS Keychain (service: monday-api-token) — see README.md.
# Copy to ~/.bob/monday.env (chmod 600) or export in your shell — do NOT commit.

MONDAY_TOKEN=your_monday_personal_api_token_here

# Optional override for Keychain service name used by scripts/monday-mcp.sh
# MONDAY_KEYCHAIN_SERVICE=monday-api-token
